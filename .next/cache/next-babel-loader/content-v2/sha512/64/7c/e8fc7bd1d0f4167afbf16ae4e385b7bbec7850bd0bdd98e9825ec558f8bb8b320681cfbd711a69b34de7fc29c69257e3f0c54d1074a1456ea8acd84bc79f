{"ast":null,"code":"import axios from \"axios\";\nconst baseUrl = process.env.BASE_URL || \"http://localhost:1337\";\n\nconst fetchQuery = (path, params = null) => {\n  let url;\n\n  if (params !== null) {\n    url = `${baseUrl}/${path}/${params}`;\n  } else {\n    url = `${baseUrl}/${path}`;\n  }\n\n  const res = axios(`${url}`);\n  const posts = res;\n  return posts;\n};\n\nexport { baseUrl, fetchQuery };","map":null,"metadata":{},"sourceType":"module"}